{
  "$schema": "https://json.schemastore.org/tsconfig",

  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],

    "moduleResolution": "bundler",
    "strict": true,

    "skipLibCheck": true,
    "noEmit": true,

    "types": ["node"]
  },

  "include": ["vite.config.ts"]
}